# ===========================================
# vitaOS - Environment Variables
# ===========================================
# Copie este arquivo para .env.local e preencha os valores

# ===========================================
# DATABASE (Neon PostgreSQL - Free Tier)
# ===========================================
# Crie uma conta em: https://neon.tech
# Crie um novo projeto e copie a connection string
DATABASE_URL="postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/vitaos?sslmode=require"

# ===========================================
# AUTHENTICATION
# ===========================================
# Gere um secret com: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-characters-long"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# OPENAI (AI Assistant - $18 free credits)
# ===========================================
# Crie uma conta em: https://platform.openai.com
# Vá em Settings > API Keys > Create new secret key
OPENAI_API_KEY="sk-..."

# ===========================================
# DAILY.CO (Video Calls - 10K mins free/month)
# ===========================================
# Crie uma conta em: https://daily.co
# Vá em Settings > API Key
DAILY_API_KEY="..."

# ===========================================
# UPSTASH (Redis - Rate Limiting - Free Tier)
# ===========================================
# Crie uma conta em: https://upstash.com
# Crie um Redis database e copie as credenciais
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."